{
	"name": "streamer-emotes",
	"type": "module",
	"version": "0.1.2",
	"description": "A library to get Twitch, BTTV, FFZ and 7TV emotes for a given Twitch channel.",
	"keywords": [
		"streamer",
		"emotes",
		"twitch",
		"bttv",
		"ffz",
		"7tv"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ahmedrangel/streamer-emotes.git"
	},
	"homepage": "https://github.com/ahmedrangel/streamer-emotes",
	"author": {
		"name": "Ahmed Rangel",
		"email": "ahmedrangel@outlook.com",
		"url": "https://ahmedrangel.com"
	},
	"scripts": {
		"build": "obuild",
		"dev": "node playground/index.ts",
		"lint": "eslint",
		"test:types": "tsc --noEmit"
	},
	"main": "./dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"gql-payload": "^2.1.0",
		"ofetch": "^2.0.0-alpha.3"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"changelogen": "^0.6.2",
		"eslint": "^10.0.3",
		"eslint-plugin-import-x": "^4.16.2",
		"obuild": "^0.4.32",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.32.1"
}
